RewriteEngine On

# 1. Protect Sensitive Files
<FilesMatch "^\.(htaccess|htpasswd|env|ini|log|sh|inc|swp|bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# 2. Prevent Directory Listing
Options -Indexes

# 3. Disable Server Signature
ServerSignature Off

# 4. Security Headers
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    # Hide PHP Version Leak
    Header unset X-Powered-By
    Header unset Server
    # HSTS (Force HTTPS for 1 Year)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header set Permissions-Policy "geolocation=(), megaphone=(), camera=(), microphone=()"
</IfModule>

# 5. Block Direct Access to Backend Folders
RedirectMatch 403 ^/component/.*$
RedirectMatch 403 ^/views/.*$

# 6. Protect Uploads Directory from Script Execution
<Directory "uploads">
    RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .phps .pl .py .jsp .asp .sh .cgi
    Options -ExecCGI
    AllowOverride None
</Directory>

# 6. Block Malicious User Agents (Basic Protection)
RewriteCond %{HTTP_USER_AGENT} (libwww-perl|curl|python|nikto|scan|sqlmap|w3af|nmap) [NC]
RewriteRule .* - [F,L]

# 7. Block Trace and Track Methods
RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK)
RewriteRule .* - [F]

# 8. Strongly Block Access to .env via Rewrite
RewriteRule ^\.env - [F,L]
RewriteRule \.env$ - [F,L]

# Redirect to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php [L,QSA]

# Enable caching for static files
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
